# ============================================
# 🛡️ Super Todo - Environment Variables
# ============================================

# DEV deployment URL (from .env.local after running `bunx convex dev`)
# Format: https://<deployment-name>.convex.cloud
CONVEX_URL=https://your-dev-deployment.convex.cloud

# PROD deployment (only for production use)
# CONVEX_URL=https://your-prod-deployment.convex.cloud

# CONVEX_DEPLOY_KEY is only needed for CI/CD deployments
# CONVEX_DEPLOY_KEY=your-deploy-key-here

# ============================================
# MCP SERVER CONFIGURATION
# ============================================

# Transport mode: "stdio" (default, local) or "sse" (HTTP server for remote)
# MCP_TRANSPORT=stdio

# HTTP server settings (only used when MCP_TRANSPORT=sse)
# MCP_HOST=0.0.0.0
# MCP_PORT=3000

# Server identity (optional, defaults shown)
# MCP_SERVER_NAME=super-todo
# MCP_SERVER_VERSION=1.0.0

# ============================================
# NOTIFICATION WEBHOOKS (Optional)
# ============================================
# These should ALSO be set in Convex Dashboard > Settings > Environment Variables
# for server-side notifications to work (schedulers, webhooks, etc.)
#
# Discord: Create webhook in Server Settings > Integrations
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
#
# Discord User ID (for @mentions / push notifications)
# Right-click your profile → Copy User ID (enable Developer Mode first)
# USER_DISCORD_ID=123456789012345678
#
# Telegram: Get bot token from @BotFather
# For groups: Add bot to group, then use @getidsbot to get group_id
# BOT_TOKEN=your-bot-token
# GROUP_ID=-1001234567890
#
# Telegram User ID (for direct priority messages that bypass group mute)
# Message @userinfobot to get your ID
# USER_TELEGRAM_ID=123456789
