{
  "name": "super-todo",
  "version": "1.0.0",
  "description": "🛡️ Super Todo - The Ultimate TODO MCP with Convex Backend",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "super-todo": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun dist/index.js",
    "cli": "bun src/cli/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy"
  },
  "keywords": [
    "mcp",
    "convex",
    "todo",
    "project-management",
    "sentinel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "convex": "^1.17.4",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
